{
    "version": 2,
    "builds": [
      {
        "src": "index.js",
        "use": "@vercel/node",
        "config": {
          "includeFiles": ["prisma/schema.prisma", "public/**"]
        }
      }
    ],
    "routes": [
      {
        "src": "/image/(.*)",
        "dest": "/public/image/$1"
      },
      {
        "src": "/(.*)",
        "dest": "/index.js"
      }
    ]
  }